{
    "name": "sushi-market/digitalkassa-sdk",
    "description": "PHP SDK for DigitalKassa API v2.1",
    "keywords": ["digitalkassa", "api", "php", "sdk", "receipt"],
    "license": "MIT",
    "authors": [
        {
            "name": "m0nclous",
            "email": "m0nclous@vk.com",
            "homepage": "https://t.me/m0nclous"
        }
    ],
    "require": {
        "php": "^8.4",
        "guzzlehttp/guzzle": "^7.10",
        "brick/json-mapper": "^0.2.1"
    },
    "require-dev": {
        "laravel/pint": "^1.25.0",
        "phpunit/phpunit": "^13.0",
        "psy/psysh": "^0.12.14",
        "symfony/var-dumper": "^8.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "DF\\DigitalKassa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "pint --test",
        "stan": "phpstan analyse --memory-limit=512M --no-progress"
    }
}
